# go配置
#export CODEDIR="/Users/gavin/Library/Mobile\\ Documents/com~apple~CloudDocs/2code"
WHOAMI=`whoami`
export CODEDIR="/Users/gavin/work"
export TOOLDIR="$CODEDIR/tool"

export GOROOT=$TOOLDIR/go
export GOBIN=$TOOLDIR/go/bin
export GOPATH=$CODEDIR/gopath

export PATH=$PATH:$GOROOT/bin
export PATH=$PATH:$GOPATH/bin
export PATH=$PATH:/opt/boxen/homebrew/bin:/usr/local/sbin
export PATH=$PATH:/usr/local/vim/bin/

#一些命令的配置
alias gopath='cd "$GOPATH"'
alias vi="vim"
alias grep="grep -n --color"

alias relay='ssh 10.70.7.140'
alias work='cd "/Users/gavin/Library/Mobile Documents/com~apple~CloudDocs/2code/work"'
alias prometheus='cd "/Users/gavin/Library/Mobile Documents/com~apple~CloudDocs/2code/work/Prometheus"'
alias sreworks='smc-toc 10.105.0.182'
alias canary='cd /Users/gavin/work/gopath/src/git.garena.com/gavin.gao/deployment-principle-audit'
alias smapspare='smc-toc 10.70.175.95'

export PATH=/usr/local/Cellar/git/2.25.0_1:$PATH
export PATH=/Users/gavin/Library/Python/2.7/bin:$PATH

export GO111MODULE=on
export GOSUMDB=off
export GOPROXY=https://goproxy.io,direct
export GOPRIVATE=git.garena.com/shopee,git.garena.com/shopee-server,git.garena.com

# tmux
alias tnew='tmux new -s'
alias tdetach='tmux detach'
alias tattach='tmux a -t'
alias tls='tmux ls'
alias trename='tmux rename-session -t'
