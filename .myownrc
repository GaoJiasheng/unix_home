WHOAMI=`whoami`
export CODEDIR="/Users/${WHOAMI}/work"
export TOOL_DIR="$CODEDIR/tool"

export GOROOT=$TOOL_DIR/go/go
export GOBIN=$TOOL_DIR/go/go/bin
export GOPATH=$TOOL_DIR/gopath

export PATH=$PATH:$GOROOT/bin
export PATH=$PATH:$GOPATH/bin
export PATH=$PATH:/opt/boxen/homebrew/bin:/usr/local/sbin
export PATH=$PATH:/usr/local/vim/bin/

#一些命令的配置
alias gopath='cd "$GOPATH"'
alias vi="vim"
alias grep="grep -n --color"

alias work='cd "/Users/gavin/work"'
alias doc='cd "/Users/gavin/obsidian"'
alias blog='cd "/Users/gavin/blog"'

# tmux
alias tnew='tmux new -s'
alias tdetach='tmux detach'
alias tattach='tmux a -t'
alias tls='tmux ls'
alias trename='tmux rename-session -t'
